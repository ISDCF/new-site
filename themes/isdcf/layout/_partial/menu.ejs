<%
  // Renders theme.menu (a plain object, at most two levels deep) as
  // Bootstrap nav / dropdown markup: each top-level entry is either a
  // plain link, or a dropdown containing a flat list of links.
  function hasActiveDescendant(obj) {
    return Object.keys(obj).some(function (key) {
      return is_current(obj[key]);
    });
  }

  function slugify(key) {
    return key.toString().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  }
%>
<% Object.keys(items).forEach(function (key) { %>
  <% var value = items[key]; %>
  <% if (typeof value === 'string') { %>
    <li class="nav-item">
      <a class="nav-link<%- is_current(value) ? ' active' : '' %>" href="<%- url_for(value) %>"><%= key %></a>
    </li>
  <% } else { %>
    <% var id = 'nav-dropdown-' + slugify(key); %>
    <li class="nav-item dropdown">
      <a class="nav-link dropdown-toggle<%- hasActiveDescendant(value) ? ' active' : '' %>" href="#" id="<%- id %>" role="button"
        data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false"><%= key %></a>
      <div class="dropdown-menu dropdown-menu-end" aria-labelledby="<%- id %>">
        <% Object.keys(value).forEach(function (subKey) { %>
          <a class="dropdown-item<%- is_current(value[subKey]) ? ' active' : '' %>" href="<%- url_for(value[subKey]) %>"><%= subKey %></a>
        <% }) %>
      </div>
    </li>
  <% } %>
<% }) %>
