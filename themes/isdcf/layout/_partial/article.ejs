<article class="post <%= index ? 'post--card' : 'post--full' %>">
  <header class="post__header">
    <h1 class="post__title">
      <% if (index) { %>
        <a href="<%- url_for(post.path) %>"><%= post.title || '(untitled)' %></a>
      <% } else { %>
        <%= post.title || '(untitled)' %>
      <% } %>
    </h1>
    <div class="post__meta">
      <% if (post.date) { %>
        <time datetime="<%= post.date.toISOString() %>"><%= date(post.date, config.date_format) %></time>
      <% } %>
      <% if (post.categories && post.categories.length) { %>
        <span class="post__categories">
          <% post.categories.forEach(function(cat){ %>
            <a href="<%- url_for(cat.path) %>"><%= cat.name %></a>
          <% }) %>
        </span>
      <% } %>
    </div>
  </header>

  <div class="post__content">
    <% if (index && post.excerpt) { %>
      <%- post.excerpt %>
      <a class="post__more" href="<%- url_for(post.path) %>#more"><%= theme.excerpt_link || 'Read more' %> &rarr;</a>
    <% } else { %>
      <%- post.content %>
    <% } %>
  </div>

  <% if (post.tags && post.tags.length) { %>
    <footer class="post__tags">
      <% post.tags.forEach(function(tag){ %>
        <a href="<%- url_for(tag.path) %>">#<%= tag.name %></a>
      <% }) %>
    </footer>
  <% } %>

  <% if (!index && (post.prev || post.next)) { %>
    <nav class="post__pager">
      <% if (post.prev) { %>
        <a class="post__pager-link post__pager-link--prev" href="<%- url_for(post.prev.path) %>">&larr; <%= post.prev.title || '(untitled)' %></a>
      <% } %>
      <% if (post.next) { %>
        <a class="post__pager-link post__pager-link--next" href="<%- url_for(post.next.path) %>"><%= post.next.title || '(untitled)' %> &rarr;</a>
      <% } %>
    </nav>
  <% } %>
</article>
