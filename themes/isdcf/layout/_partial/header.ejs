<header class="site-header">
  <nav class="navbar navbar-expand-lg bg-white border-bottom d-print-none" data-bs-theme="light">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center" href="<%- url_for('/') %>">
        <img src="<%- url_for(theme.logo_url) %>" height="40" alt="<%= theme.logo || config.title %>">
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#site-nav"
        aria-controls="site-nav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="site-nav">
        <ul class="navbar-nav ms-auto">
          <% if (theme.menu) { %>
            <%- partial('_partial/menu', { items: theme.menu, level: 0 }) %>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
</header>
