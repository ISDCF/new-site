<% if (page.current === 1) { %>
  <header class="page-intro">
    <h1 class="page-intro__title"><%= config.title %></h1>
    <% if (config.subtitle) { %><p class="page-intro__subtitle"><%= config.subtitle %></p><% } %>
  </header>
<% } %>

<div class="post-list">
  <% page.posts.each(function(post){ %>
    <%- partial('_partial/article', {post: post, index: true}) %>
  <% }) %>
</div>

<%- partial('_partial/pagination') %>
